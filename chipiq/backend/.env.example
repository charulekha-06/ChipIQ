# Jira integration settings for ticket creation endpoint
# Copy this file to backend/.env and fill real values.
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=CHIP

# Optional Kafka event bus settings (Phase 1 scaffold)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=chipiq-backend
KAFKA_TOPIC_INGESTION=chipiq.ingestion.raw
KAFKA_TOPIC_JIRA=chipiq.jira.events
KAFKA_TOPIC_LOGS_RAW=logs.raw
KAFKA_TOPIC_BUGS_RAW=bugs.raw
KAFKA_TOPIC_COVERAGE_RAW=coverage.raw
KAFKA_TOPIC_REGRESSION_RAW=regression.raw
KAFKA_TOPIC_ALERTS=chipiq.alerts.events

# Optional Spark ETL settings (Step 2 scaffold)
SPARK_ENABLED=false
SPARK_MASTER=local[*]
SPARK_APP_NAME=chipiq-etl
KAFKA_TOPIC_ETL=chipiq.etl.events
SPARK_KAFKA_ENABLED=false
SPARK_KAFKA_GROUP_ID=chipiq-etl-group
SPARK_KAFKA_MAX_MESSAGES=500

# Optional TimescaleDB settings (Step 3 scaffold)
TIMESCALE_ENABLED=false
TIMESCALE_DSN=postgresql://postgres:postgres@localhost:5432/chipiq
TIMESCALE_SCHEMA=public
TIMESCALE_EVENTS_TABLE=chipiq_events
TIMESCALE_AUTO_SYNC=false
KAFKA_TOPIC_TIMESCALE=chipiq.timescale.events

# Optional model serving source preference (Phase 4)
# auto | timescale | etl | uploaded | integrated
FORECAST_SOURCE=auto

# Optional alerting settings (Phase 6 scaffold)
ALERT_COVERAGE_MIN=80
ALERT_REGRESSION_PASS_MIN=85
ALERT_CRITICAL_BUGS_MAX=5
ALERT_TREND_SPIKE_PCT=15
ALERT_AUTO_TICKET=false
ALERT_SLACK_ENABLED=false
ALERT_EMAIL_ENABLED=false
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
